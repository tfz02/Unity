*.app
*.ipa
*.zip
*.7z

# Android / Gradle generated files
.gradle/
**/gradleOut/
**/launcher/build/
**/unityLibrary/build/
**/build.gradle

# OS files
.DS_Store
Thumbs.db
Desktop.ini

# Logs
*.log

